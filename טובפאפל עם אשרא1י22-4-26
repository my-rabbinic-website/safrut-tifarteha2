    <!-- Toast Success -->
    <div id="toast" class="fixed bottom-10 right-10 z-[500] pointer-events-none opacity-0 translate-y-10 transition-all duration-500">
        <div class="bg-brand-obsidian text-brand-gold px-8 py-5 rounded-2xl shadow-2xl flex items-center gap-5 border border-brand-gold/30">
            <div class="w-10 h-10 bg-brand-gold text-white rounded-full flex items-center justify-center font-black">✓</div>
            <div class="flex flex-col">
                <span class="font-black italic text-lg leading-tight">נוסף לסל בהצלחה</span>
                <span class="text-[9px] uppercase tracking-widest text-white/40 font-black">Added to secure cart</span>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        let currentCurrency = 'USD';
        const exchangeRate = 3.82; 

        const catalog = [
            { id: 1, name: "ספר תורה פרימיום", priceUSD: 58000, img: "https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=800", desc: "איכות עילית, נכתב ע\"י אמן מומחה בכתב 'בית יוסף'.", stock: "1 יח' זמינה", lowStock: true },
            { id: 2, name: "תפילין עור גסה מהודר", priceUSD: 2450, img: "https://images.unsplash.com/photo-1543002588-bfa74002ed7e?q=80&w=800", desc: "ריבועים מושלמים, עור שור גמור, בדיקת מחשב מלאה.", stock: "במלאי שוטף", lowStock: false },
            { id: 3, name: "מזוזה 'הידור' 15 ס\"מ", priceUSD: 185, img: "https://images.unsplash.com/photo-1581441363689-1f3c3c414635?q=80&w=800", desc: "כתב ברור ומאיר, קלף שילוח מהודר.", stock: "במלאי", lowStock: false },
            { id: 4, name: "סט תפילין 'חתנים'", priceUSD: 3100, img: "https://images.unsplash.com/photo-1566438480900-0609be27a4be?q=80&w=800", desc: "הסט המהודר ביותר הכולל נרתיק רקמה בעבודת יד.", stock: "סט 1 אחרון", lowStock: true },
            { id: 5, name: "מגילת אסתר יוקרתית", priceUSD: 4200, img: "https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?q=80&w=800", desc: "כתב אריז\"ל מרהיב על קלף משובח.", stock: "הזמנה מראש", lowStock: false },
            { id: 6, name: "פטום הקטורת על קלף", priceUSD: 290, img: "https://images.unsplash.com/photo-1532012197367-bb83d53a847a?q=80&w=800", desc: "סגולה לשמירה ופרנסה, כתוב בכתב סת\"ם מהודר.", stock: "זמין במלאי", lowStock: false }
        ];

        const googleReviews = [
            { name: "David Friedman, NY", rating: 5, text: "Excellent experience. The shipping was fast and the quality of the Tefillin exceeded my expectations. Total confidence.", date: "1 month ago" },
            { name: "מיכאל לוי, לונדון", rating: 5, text: "השירות הכי אדיב שנתקלתי בו. הרגשתי שיש מישהו בצד השני שדואג שהכל יגיע מושלם.", date: "לפני שבועיים" },
            { name: "Arielle B., Paris", rating: 5, text: "Mezouzas magnifiques. Livraison sécurisée et rapide. Merci pour le certificat de garantie.", date: "3 weeks ago" },
            { name: "Rabbi Cohen, Miami", rating: 5, text: "We ordered a Sefer Torah for our community. It's a masterpiece. The most professional scribes.", date: "2 months ago" }
        ];

        let cart = JSON.parse(localStorage.getItem('tifarteha_premium_cart')) || [];

        function init() {
            AOS.init({ duration: 1000, once: true });
            renderCatalog();
            renderTestimonials();
            updateUI();

            window.addEventListener('scroll', () => {
                const nav = document.getElementById('main-nav');
                if (window.scrollY > 50) {
                    nav.classList.add('shadow-xl', 'h-20');
                    nav.classList.remove('mt-8', 'h-24');
                } else {
                    nav.classList.remove('shadow-xl', 'h-20');
                    nav.classList.add('mt-8', 'h-24');
                }
            });
        }

        function setCurrency(curr) {
            currentCurrency = curr;
            document.querySelectorAll('#btn-usd, #btn-ils').forEach(btn => {
                btn.classList.remove('bg-brand-obsidian', 'text-brand-gold');
                btn.classList.add('text-brand-obsidian/40');
            });
            document.getElementById(`btn-${curr.toLowerCase()}`).classList.add('bg-brand-obsidian', 'text-brand-gold');
            renderCatalog();
            updateUI();
        }

        function formatPrice(usd) {
            return currentCurrency === 'USD' ? `$${usd.toLocaleString()}` : `₪${Math.round(usd * exchangeRate).toLocaleString()}`;
        }

        function renderCatalog() {
            const grid = document.getElementById('catalog-grid');
            grid.innerHTML = catalog.map((item, i) => `
                <div class="bg-white rounded-[2.5rem] border border-brand-platinum shadow-sm overflow-hidden relative group card-hover" data-aos="fade-up" data-aos-delay="${i * 50}">
                    <div class="relative h-72 overflow-hidden">
                        <img src="${item.img}" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
                        <div class="absolute bottom-4 right-4 bg-white/90 backdrop-blur text-brand-obsidian text-[9px] font-black px-4 py-1.5 rounded-full flex items-center gap-2 shadow-lg">
                            <span class="w-1.5 h-1.5 rounded-full ${item.lowStock ? 'bg-red-500 scarcity-tag' : 'bg-brand-success'}"></span>
                            ${item.stock}
                        </div>
                    </div>
                    <div class="p-8 text-right relative">
                        <h3 class="text-2xl font-black italic mb-2 group-hover:text-brand-gold transition-colors">${item.name}</h3>
                        <span class="text-xl font-black gold-gradient block mb-4">${formatPrice(item.priceUSD)}</span>
                        <p class="text-gray-500 font-tradition text-xs leading-relaxed h-12 overflow-hidden mb-8">${item.desc}</p>
                        <button onclick="addToCart(${item.id})" class="w-full py-4 rounded-xl border border-brand-platinum bg-brand-cream font-black text-[10px] uppercase tracking-[0.2em] hover:bg-brand-obsidian hover:text-brand-gold transition-all">
                            הוספה לסל המאובטח
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function renderTestimonials() {
            const content = googleReviews.map(r => `
                <div class="min-w-[400px] bg-white p-10 rounded-[3rem] border border-brand-platinum text-right shrink-0 shadow-sm">
                    <div class="flex justify-between items-start mb-8">
                        <div class="flex gap-1 text-brand-gold text-xs">${Array(r.rating).fill('★').join('')}</div>
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" class="w-5 h-5">
                    </div>
                    <p class="text-gray-600 font-tradition italic text-lg mb-8 leading-relaxed">"${r.text}"</p>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-brand-platinum rounded-full flex items-center justify-center font-black text-brand-darkGold text-xs">${r.name.charAt(0)}</div>
                        <div>
                            <span class="block font-black text-brand-obsidian text-sm">${r.name}</span>
                            <span class="text-[9px] text-gray-400 uppercase tracking-widest">${r.date} • Verified Purchase</span>
                        </div>
                    </div>
                </div>
            `).join('');
            document.getElementById('track-1').innerHTML = content;
            document.getElementById('track-2').innerHTML = content;
        }

        function addToCart(id) {
            const item = catalog.find(i => i.id === id);
            cart.push({ ...item, cartId: Date.now() });
            localStorage.setItem('tifarteha_premium_cart', JSON.stringify(cart));
            updateUI();
            showToast();
        }

        function removeFromCart(cartId) {
            cart = cart.filter(i => i.cartId !== cartId);
            localStorage.setItem('tifarteha_premium_cart', JSON.stringify(cart));
            updateUI();
        }

        function updateUI() {
            const itemsContainer = document.getElementById('cart-items');
            document.getElementById('cart-count').innerText = cart.length;
            
            if (cart.length === 0) {
                itemsContainer.innerHTML = `<div class="text-center py-20 opacity-20 font-tradition text-2xl italic">הסל מאובטח וריק כעת...</div>`;
            } else {
                itemsContainer.innerHTML = cart.map(item => `
                    <div class="flex items-center gap-6 pb-6 border-b border-brand-platinum group">
                        <img src="${item.img}" class="w-20 h-20 rounded-2xl object-cover shadow-md">
                        <div class="flex-1 text-right">
                            <h4 class="font-black italic text-base group-hover:text-brand-gold transition-colors">${item.name}</h4>
                            <p class="text-brand-gold font-black text-sm mt-1">${formatPrice(item.priceUSD)}</p>
                        </div>
                        <button onclick="removeFromCart(${item.cartId})" class="text-gray-300 hover:text-red-500 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                `).join('');
            }
            const totalUSD = cart.reduce((sum, i) => sum + i.priceUSD, 0);
            document.getElementById('cart-total').innerText = formatPrice(totalUSD);
        }

        function toggleCart() {
            const drawer = document.getElementById('cart-drawer');
            const overlay = document.getElementById('cart-overlay');
            const isHidden = drawer.style.transform !== 'translateX(0px)';

            if (isHidden) {
                overlay.classList.remove('hidden');
                setTimeout(() => { 
                    overlay.classList.add('active'); 
                    drawer.style.transform = 'translateX(0)'; 
                }, 10);
                document.body.style.overflow = 'hidden';
            } else {
                drawer.style.transform = 'translateX(-100%)';
                overlay.classList.remove('active');
                setTimeout(() => overlay.classList.add('hidden'), 500);
                document.body.style.overflow = '';
                setTimeout(backToCart, 500); // Reset to cart view on close
            }
        }

        function goToCheckout() {
            if (cart.length === 0) return;
            document.getElementById('cart-view').classList.add('hidden');
            document.getElementById('checkout-view').classList.remove('hidden');
            
            const summary = document.getElementById('checkout-summary');
            summary.innerHTML = cart.map(i => `
                <div class="flex justify-between text-gray-500">
                    <span>${i.name}</span>
                    <span>${formatPrice(i.priceUSD)}</span>
                </div>
            `).join('');
            
            const totalUSD = cart.reduce((sum, i) => sum + i.priceUSD, 0);
            document.getElementById('checkout-total').innerText = formatPrice(totalUSD);
        }

        function backToCart() {
            document.getElementById('checkout-view').classList.add('hidden');
            document.getElementById('cart-view').classList.remove('hidden');
        }

        function handleOrder(e) {
            e.preventDefault();
            const totalUSD = cart.reduce((sum, i) => sum + i.priceUSD, 0);
            const amount = currentCurrency === 'USD' ? totalUSD : Math.round(totalUSD * exchangeRate);
            
            // המרת פרטי הטופס לטקסט לצורך שליחה בפרמטר (אופציונלי - רק לשם הדגמה)
            const formData = new FormData(e.target);
            const name = formData.get('full_name');
            
            // מעבר מאובטח לפייפאל עם מזהה העסק
            const merchantId = "TZQ8K3PLELXLS";
            const itemName = encodeURIComponent("הזמנה מתפארתך - אומנות הסת\"ם");
            window.location.href = `https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=${merchantId}&item_name=${itemName}&amount=${amount}&currency_code=${currentCurrency}`;
        }

        function openVideoModal() {
            const modal = document.getElementById('video-modal');
            modal.classList.remove('hidden');
            setTimeout(() => modal.classList.add('active'), 10);
        }

        function closeVideoModal() {
            const modal = document.getElementById('video-modal');
            modal.classList.remove('active');
            setTimeout(() => modal.classList.add('hidden'), 400);
        }

        function showToast() {
            const t = document.getElementById('toast');
            t.style.opacity = '1'; t.style.transform = 'translateY(0)';
            setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(40px)'; }, 3000);
        }

        window.onload = init;
    </script>
